# Top-most EditorConfig file
root = true

# All files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Python files
[*.py]
indent_style = space
indent_size = 4

# Shell scripts
[*.sh]
indent_style = space
indent_size = 4

# YAML / GitHub Actions workflows
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Configuration / Data files
[*.{json,toml}]
indent_style = space
indent_size = 2

# Markdown files
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# Meson build files
[meson.build]
indent_style = space
indent_size = 4

# Windows batch / scripts
[*.{cmd,bat}]
end_of_line = crlf
